ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sukaali_check
JWT_SECRET=replace-this-with-a-real-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Email (Resend HTTP API — https://resend.com)
RESEND_API_KEY=your-resend-api-key
MAIL_FROM=noreply@sukaalicheck.com
ADMIN_EMAIL=sukaalicheckug@gmail.com

# MTN MoMo Collection API (https://momodeveloper.mtn.com)
# MOMO_SUBSCRIPTION_KEY = the Collection product primary key (Ocp-Apim-Subscription-Key).
# MOMO_API_USER / MOMO_API_KEY: sandbox — generate via scripts/provision_momo_sandbox.py;
#   production — provided by MTN during onboarding.
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
# sandbox: MOMO_TARGET_ENVIRONMENT=sandbox, MOMO_CURRENCY=EUR, MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# production (Uganda): MOMO_TARGET_ENVIRONMENT=mtnuganda, MOMO_CURRENCY=UGX, MOMO_BASE_URL=https://proxy.momoapi.mtn.com
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CURRENCY=EUR
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# Only needed when running the sandbox provisioning helper:
MOMO_CALLBACK_HOST=https://sukaalicheck.com
